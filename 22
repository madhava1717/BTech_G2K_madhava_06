#include <stdio.h>

#define SIZE 5 // Define a constant for the array size

int main() {
    int array1[SIZE], array2[SIZE], sum_array[SIZE];
    int i;

    // Input elements for the first array
    printf("Enter %d elements for the first array:\n", SIZE);
    for (i = 0; i < SIZE; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &array1[i]);
    }

    // Input elements for the second array
    printf("\nEnter %d elements for the second array:\n", SIZE);
    for (i = 0; i < SIZE; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &array2[i]);
    }

    // Calculate the sum of corresponding elements and store in the third array
    for (i = 0; i < SIZE; i++) {
        sum_array[i] = array1[i] + array2[i];
    }

    // Print the elements of the sum array
    printf("\nSum of corresponding elements (third array):\n");
    for (i = 0; i < SIZE; i++) {
        printf("Sum[%d] = %d\n", i, sum_array[i]);
    }

    return 0;
}
