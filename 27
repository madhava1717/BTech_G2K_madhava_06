#include <stdio.h>

int main() {
    int m, n, i, j, sum = 0;

    printf("Enter number of rows (m) and columns (n): ");
    scanf("%d %d", &m, &n);

    // Diagonal elements only exist in a square matrix (m == n)
    if (m != n) {
        printf("Diagonal sum is not defined for a non-square matrix.\n");
        return 0;
    }

    int matrix[m][n];
    printf("Enter elements of the matrix:\n");
    for (i = 0; i < m; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    // Calculating sum of diagonal elements (where row == col)
    for (i = 0; i < m; i++) {
        sum += matrix[i][i];
    }

    printf("Sum of diagonal elements: %d\n", sum);

    return 0;
}
